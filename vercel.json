{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run validate",
  "outputDirectory": "viz",
  "installCommand": "echo \"no dependencies\"",
  "headers": [
    {
      "source": "/data/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    }
  ]
}
